# 복사해서 .env 로 저장 (python-dotenv 자동 로드). === 전 구성요소 로컬(DGX Spark) 기준 ===
# 클라우드(Upstage/CLOVA/NCLOUD/게이트웨이)는 로컬 전환으로 모두 제거됨.
# 서빙: Ollama(OpenAI 호환, :11434). 저장소: SQLite + 로컬 하이브리드(Docker 불필요).

# ========== 추론 LLM (로컬 Ollama, OpenAI 호환) ==========
OPENAI_API_KEY=ollama                  # Ollama는 키 불필요(아무 값이나)
OPENAI_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3.5:35b-a3b              # MoE 3B-active, 멀티모달(Text+Image)
LLM_SEED=42
SELF_CONSISTENCY_N=1                  # 1=비활성. 일관성 실험 시 5 등

# ========== 임베딩 (로컬 BGE-M3) ==========
EMBED_BACKEND=local                   # local=sentence-transformers/FlagEmbedding | hash(오프라인)
LOCAL_EMBED_MODEL=BAAI/bge-m3         # dense(+sparse는 FlagEmbedding 연동 시)

# ========== 시각-언어 VLM (이미지 캡션·OCR fallback) ==========
# qwen3.5가 멀티모달이라 메인 LLM과 동일 엔드포인트·모델 재사용.
VLM_BASE_URL=http://localhost:11434/v1
VLM_MODEL=qwen3.5:35b-a3b

# ========== 음성 STT (로컬 faster-whisper, in-process) ==========
# 코드 연동 완료. 인프로세스 실행(모델 최초 1회 자동 다운로드).
STT_BACKEND=faster_whisper
WHISPER_MODEL=large-v3-turbo
STT_DEVICE=cuda                       # cuda | cpu
STT_COMPUTE_TYPE=float16              # cuda=float16 | cpu=int8

# ========== OCR / 문서 파싱 (로컬) ==========
# 코드 연동 완료. surya는 'pip install surya-ocr' 필요 — 미설치/실패 시 vlm 자동 폴백.
OCR_BACKEND=vlm                       # vlm(견고·기본) | surya | paddleocr

# ========== 근거 검증 (로컬 LLM 판정) ==========
# 코드 연동 완료. 로컬 LLM(chat)으로 근거 판정.
GROUNDEDNESS_BACKEND=local_llm        # local_llm | off

# ========== 저장소 (Docker 불필요 · 경량 폴백) ==========
RELATIONAL_BACKEND=sqlite             # sqlite | postgres
DB_PATH=./forensic.db                 # sqlite 경로
VECTOR_BACKEND=local                  # local(BM25+dense 하이브리드) | milvus | hash
# (postgres/milvus 쓸 때만)
# DATABASE_URL=postgresql://forensic:forensic@localhost:5544/forensic
# MILVUS_URI=http://localhost:19530

# ========== 동작 파라미터 ==========
NER_TYPES=인물,날짜,금액,계좌,장소
PARSE_QUALITY_THRESHOLD=0.6
SEARCH_MAX_ITERS=4
TOPK=5
